generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL") //error est du au update de version de prima
}

// USER
model User {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  age         Int?
  typeCompte  TypeCompte @default(classique)
  email       String     @unique
  password    String?
  phone       String?
  avatar      String?
  companyName String?
  companyLogo String?

  role UserRole @default(visitor)

  accountStatus AccountStatus @default(unverified)

  city       String?
  country    String?
  profession String?
  services   String?

  docJust         String?
  docCNI          String?
  docDiplome      String?
  docContribuable String?
  docRCCM         String?

  authProvider AuthProvider @default(local)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
}

enum UserRole {
  visitor
  owner
  property_manager
  prospector
  agency
  agent
  admin
}

enum AuthProvider {
  local
  google
}

enum TypeCompte {
  classique
  premium
}

enum AccountStatus {
  unverified
  pending
  verified
  suspended
  verifiedPremium
}

