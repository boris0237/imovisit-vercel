generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  avatar    String?
  role      UserRole @default(visitor)
  verified  Boolean  @default(false)
  city      String?
  country   String?
  createdAt DateTime @default(now())
}

enum UserRole {
  visitor
  owner
  agency
  agent
  admin
}
