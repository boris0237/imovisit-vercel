generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// USER
model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  age         Int?

  typeCompte  String   @default("classique") // TypeCompte : classique | premium
  email       String   @unique
  password    String?
  phone       String?
  avatar      String?

  companyName String?
  companyLogo String?
  providerType String?

  role        String   @default("visitor") // UserRole : visitor | owner | property_manager | prospector | provider | free_agent | agency | agent | admin
  accountStatus String @default("unverified") // AccountStatus : unverified | pending | verified | suspended | verifiedPremium

  city        String?
  country     String?
  profession  String?
  services    String?

  docJust         String?
  docCNI          String?
  docDiplome      String?
  docContribuable String?
  docRCCM         String?

  authProvider String @default("local") // AuthProvider : local | google

  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}


// PROPERTY
model Property {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  title             String
  description       String
  price             Float

  priceType         String // PriceType : monthly | daily | sale
  type              String // PropertyType : apartment | house | studio | villa | duplex | land | office | shop | building | cleaning
  offerType         String // OfferType : rent | sale | furnished

  city              String
  neighborhood      String  // Quartier spécifique
  address           String  // Adresse exacte

  surface           Float?
  rooms             Int     // Nombre total de pièces
  bedrooms          Int?    // Nombre de chambres
  bathrooms         Int?    // Nombre de salles de bain

  images            String[]
  amenities         String[] // Amenity : pool | elevator | parking | gym | garden | security | water | borehole

  visitType         String // PropertyVisitType : in_person | remote | both
  visitFee          Float? // Frais éventuels pour la visite

  isAvailable       Boolean @default(true)
  docTitreFoncier   String? // Document de propriété

  userId            String
  userName          String
  userCompanyName   String?
  userCompanyLogo   String?
  userVerified      String // AccountStatus
  userAvatar        String?

  views             Int @default(0)
  visitsCount       Int @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// FAVORIS
model Favorite {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  propertyId String
  userId     String
  createdAt  DateTime @default(now())
}


// AGENDA
model AvailabilityRule { // règles de disponibilité du propriétaire
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  ownerId   String
  date      DateTime? // date spécifique (optionnel)
  dayOfWeek Int? 

  startTime String
  endTime   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AvailabilityException { // exceptions aux disponibilités
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  ownerId   String
  date      DateTime?

  // intervalle de jours
  dateStart DateTime?
  dateEnd   DateTime?

  // plage horaire bloquée
  startTime String?
  endTime   String?

  reason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// RESERVATION
model Reservation { // réservations de visite
  id          String   @id @default(auto()) @map("_id") @db.ObjectId

  propertyId  String
  ownerId     String
  clientId    String

  date        DateTime
  startTime   String
  endTime     String

  visitType   String @default("in_person") // ReservationVisitType : in_person | remote
  visitContext String? // contexte de la visite (zoom, whatsapp, etc.)

  status      String @default("pending") // ReservationStatus : pending | confirmed | cancelled

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


// GEOLOCALISATION
model Country { // pays
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  code      String
  isActive  Boolean  @default(true)

  cities    City[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name])
  @@unique([code])
}

model City { // ville
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  countryId String   @db.ObjectId

  country   Country  @relation(fields: [countryId], references: [id])

  districts District[]

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, countryId]) // unique par pays
}

model District { // quartier
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  cityId    String   @db.ObjectId

  city      City     @relation(fields: [cityId], references: [id])

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, cityId]) // unique par ville
}


// DEPENSES
model Expense {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  assetId     String   @db.ObjectId // id du bien

  type        String   // ExpenseType : maintenance | repair | insurance | transport | other
  amount      Float
  currency    String   // devise (USD, EUR, XAF)

  date        DateTime
  description String?
  vendor      String?  // la personne ou entreprise qui a fait le service

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


// LOCATAIRES
model Tenant {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId

  firstName String
  lastName  String
  email     String?  @unique
  phone     String

  assetId   String   @db.ObjectId // id du bien
  address   String?

  startDate DateTime // date de début de location
  endDate   DateTime // date de fin de location

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}


